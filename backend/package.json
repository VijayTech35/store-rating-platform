{
  "name": "rating-app-backend",
  "version": "1.0.0",
  "description": "Full-stack rating application backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "cd ../frontend && npm install && npm run build",
    "db:init": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "test": "jest --forceExit --detectOpenHandles",
    "lint": "eslint src/ __tests__/ --max-warnings 50"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
